# TinyFish API Key (Required for agent extraction)
TINYFISH_API_KEY=

# Claude API Key (Required for analyzing scraped data - extraction)
# Use CLAUDE_API_KEY or ANTHROPIC_API_KEY (e.g. from Cursor Secrets)
CLAUDE_API_KEY=

# Scrape.do API Key (Optional, fallback for web scraping)
# Prefer SCRAPE_DO_API_KEY (no dot) for compatibility; SCRAPE.DO_API_KEY also works
SCRAPE_DO_API_KEY=

# Jina Reader API Key (Optional, fallback for web scraping)
JINA_READER_API_KEY=

# Firecrawl API Key (Optional, fallback for web scraping)
FIRECRAWL_API_KEY=